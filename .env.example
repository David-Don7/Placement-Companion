# MongoDB Connection String (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/placement-companion

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Environment
NODE_ENV=production

# Port (Optional - Vercel manages this)
PORT=5000

# Optional: Judge0 API for real code execution
# JUDGE0_API=https://judge0-ce.p.rapidapi.com
# JUDGE0_KEY=your_judge0_rapidapi_key
